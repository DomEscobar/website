---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/portfolio/Navbar.astro';
import { agentTopics, topicPath } from '@/lib/agent-topics';

export const prerender = true;
---

<BaseLayout
  locale="de"
  title="Themen | Hücki"
  description="Agentenlesbare Themen-Hubs fuer das Huecki AI-first Engineering Wiki."
  path="/topics/"
  alternatePaths={{ de: '/topics/', en: '/topics/' }}
>
  <Navbar locale="de" />
  <main id="main-content" class="px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <section class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent">Agent Wiki</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight md:text-6xl">Themen</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-muted-foreground">
        Stabile Einstiegspunkte fuer Agenten und Leser. Jeder Hub buendelt passende Huecki-Artikel, Tools und maschinenlesbare Exporte.
      </p>
      <div class="mt-12 grid gap-4 md:grid-cols-2">
        {agentTopics.map((topic) => (
          <a href={topicPath('de', topic.id)} class="rounded-md border border-border/70 bg-card/60 p-6 transition hover:border-accent/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <h2 class="text-2xl font-bold">{topic.labels.de}</h2>
            <p class="mt-3 leading-7 text-muted-foreground">{topic.descriptions.de}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
