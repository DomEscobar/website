---
import { getCollection } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, localizedPath, person, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

export const prerender = true;
const locale: Locale = 'en';
const copy = portfolioCopy[locale].blog;
const contactHref = `mailto:${person.email}?subject=${encodeURIComponent('Project inquiry for Hücki')}`;
const posts = (await getCollection('blog'))
  .filter((post) => post.data.language === locale && !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const postBySlug = new Map(posts.map((post) => [post.data.slug, post]));
const focusPosts = [
  'natural-language-agent-harnesses',
  'agent-state-machines-seatbelts',
  'ai-agents-need-evidence-before-clicking',
  'agents-need-exit-conditions',
  'ai-self-check-always-finds-something',
]
  .map((slug) => postBySlug.get(slug))
  .filter(Boolean);
---

<BaseLayout locale={locale} title={`${copy.title} | Hücki`} description={copy.description} path="/blog/" jsonLd={[{
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: copy.title,
  description: copy.description,
  inLanguage: 'en-US',
}]}>
  <Navbar locale={locale} />
  <main id="main-content" class="px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <section class="mx-auto max-w-7xl">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent">{copy.eyebrow}</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight md:text-7xl">{copy.title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-muted-foreground">{copy.description}</p>
      </div>
      {focusPosts.length > 0 && (
        <section class="mt-12 overflow-hidden rounded-xl border border-accent/30 bg-card/70 shadow-[0_24px_80px_hsl(var(--background)/0.35)]">
          <div class="grid gap-0 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
            <div class="border-b border-border/70 p-6 md:p-8 lg:border-b-0 lg:border-r">
              <p class="text-xs font-semibold uppercase tracking-[0.28em] text-accent">Detected Focus</p>
              <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">Agent Harnesses</h2>
              <p class="mt-5 text-lg leading-8 text-foreground/90">
                Several recent posts point to the same engineering problem: agents do not only need better prompts.
                They need a runtime contract around the prompt.
              </p>
              <div class="mt-6 rounded-lg border border-border/70 bg-background/60 p-4">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-muted-foreground">The minimal model</p>
                <p class="mt-3 leading-7 text-muted-foreground">
                  A useful harness defines the agent’s phase, allowed actions, required evidence, exit condition,
                  and blocker rules. That is the difference between an AI that tries to help and an agent that can be operated.
                </p>
              </div>
              <details class="group mt-5 rounded-lg border border-border/70 bg-background/40 p-4">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-semibold text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                  <span>Read the full 2-minute summary</span>
                  <span class="text-accent transition group-open:rotate-45" aria-hidden="true">＋</span>
                </summary>
                <div class="mt-4 space-y-4 leading-7 text-muted-foreground">
                  <p>
                    An agent harness is the control layer around an AI agent. It defines allowed actions, state transitions,
                    required evidence, and stop conditions.
                  </p>
                  <p>
                    Without a harness, the model decides too much from chat context. It may edit before inspecting,
                    mark work done without running checks, keep looping after the useful work is finished, or create fake
                    review comments because the prompt asked it to criticize.
                  </p>
                  <p>
                    The practical fix is to move those rules out of vibes and into an explicit contract: phase state controls
                    which actions are allowed; evidence gates control when the agent may claim progress; exit conditions
                    control when the loop stops; blocker rules control when the agent must ask for help; review rules prevent
                    pointless self-critique.
                  </p>
                </div>
              </details>
            </div>
            <div class="p-6 md:p-8">
              <p class="text-sm font-semibold text-muted-foreground">Related reading</p>
              <div class="mt-4 grid gap-3">
                {focusPosts.map((post, index) => post && (
                  <a
                    href={localizedPath(locale, `/blog/${post.data.slug}/`)}
                    class="group rounded-lg border border-border/70 bg-background/45 p-4 transition hover:border-accent/70 hover:bg-background/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                  >
                    <div class="flex gap-4">
                      <span class="mt-1 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-border bg-card text-xs font-semibold text-muted-foreground group-hover:border-accent group-hover:text-accent">
                        {String(index + 1).padStart(2, '0')}
                      </span>
                      <div>
                        <h3 class="font-semibold leading-6 text-foreground group-hover:text-accent">{post.data.title}</h3>
                        <p class="mt-2 line-clamp-2 text-sm leading-6 text-muted-foreground">{post.data.summary}</p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>
      )}
      <div class="mt-12 grid gap-6">
        {posts.map((post) => (
          <article class="rounded-md border border-border/70 bg-card/60 p-6 transition hover:-translate-y-1 hover:border-accent/80 md:p-8">
            <p class="text-sm text-muted-foreground">{formatDate(post.data.publishedAt, locale)} · {post.data.topic}</p>
            <h2 class="mt-3 text-2xl font-bold tracking-tight md:text-3xl">
              <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{post.data.title}</a>
            </h2>
            <p class="mt-4 max-w-3xl leading-7 text-muted-foreground">{post.data.summary}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => <span class="rounded-full border border-border bg-background px-3 py-1 text-xs font-medium text-foreground/80">{tag}</span>)}
            </div>
            <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="mt-6 inline-flex text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{copy.readMore}</a>
          </article>
        ))}
      </div>
      <section class="mt-14 rounded-md border border-border/70 bg-card/70 p-6 md:p-8">
        <h2 class="text-2xl font-bold tracking-tight">{copy.ctaTitle}</h2>
        <p class="mt-3 max-w-2xl leading-7 text-muted-foreground">{copy.ctaText}</p>
        <a href={contactHref} class="mt-6 inline-flex min-h-11 items-center rounded-md bg-accent px-5 py-3 text-sm font-semibold text-accent-foreground transition hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{copy.ctaButton}</a>
      </section>
    </section>
  </main>
</BaseLayout>
