---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/portfolio/Navbar.astro';
import { blogPath, toolPath } from '@/lib/agent-readable';
import { agentTopics, getEntryTopicIds, topicPath, type AgentReadableEntry } from '@/lib/agent-topics';
import { absoluteUrl } from '@/lib/site';

export const prerender = true;

export async function getStaticPaths() {
  return agentTopics.map((topic) => ({
    params: { slug: topic.id },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const [posts, tools] = await Promise.all([getCollection('blog'), getCollection('tools')]);
const entries = [...posts, ...tools]
  .filter((entry) => entry.data.language === 'en' && !entry.data.draft && getEntryTopicIds(entry as AgentReadableEntry).includes(topic.id))
  .sort((a, b) => {
    const dateA = 'publishedAt' in a.data ? a.data.publishedAt.valueOf() : 0;
    const dateB = 'publishedAt' in b.data ? b.data.publishedAt.valueOf() : 0;
    return dateB - dateA;
  });
const startEntry = entries.find((entry) => entry.data.slug === topic.startHere);
const pagePath = `/topics/${topic.id}/`;
const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: topic.labels.en,
  description: topic.descriptions.en,
  inLanguage: 'en-US',
  mainEntityOfPage: absoluteUrl(topicPath('en', topic.id)),
  hasPart: entries.map((entry) => ({
    '@type': entry.collection === 'blog' ? 'BlogPosting' : 'CreativeWork',
    name: entry.data.title,
    url: absoluteUrl(entry.collection === 'blog' ? blogPath(entry) : toolPath(entry)),
  })),
}];
---

<BaseLayout
  locale="en"
  title={`${topic.labels.en} | Hücki Topics`}
  description={topic.descriptions.en}
  path={pagePath}
  alternatePaths={{ de: pagePath, en: pagePath }}
  jsonLd={jsonLd}
>
  <Navbar locale="en" />
  <main id="main-content" class="px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <article class="mx-auto max-w-5xl">
      <a href="/en/topics/" class="text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">← All topics</a>
      <p class="mt-8 text-sm font-semibold uppercase tracking-[0.24em] text-accent">Agent Wiki Topic</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight md:text-6xl">{topic.labels.en}</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-muted-foreground">{topic.descriptions.en}</p>
      <section class="mt-10 rounded-md border border-border/70 bg-card/70 p-6">
        <h2 class="text-xl font-bold">Agent-readable entry points</h2>
        <div class="mt-4 grid gap-2 text-sm text-muted-foreground">
          <a class="text-accent hover:text-foreground" href="/llms.txt">/llms.txt</a>
          <a class="text-accent hover:text-foreground" href="/llms-full.txt">/llms-full.txt</a>
          <a class="text-accent hover:text-foreground" href="/knowledge-map.json">/knowledge-map.json</a>
        </div>
      </section>
      {startEntry && (
        <section class="mt-10 border-l-2 border-accent pl-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground">Start here</p>
          <h2 class="mt-3 text-2xl font-bold">
            <a class="hover:text-accent" href={startEntry.collection === 'blog' ? blogPath(startEntry) : toolPath(startEntry)}>{startEntry.data.title}</a>
          </h2>
          <p class="mt-3 leading-7 text-muted-foreground">{startEntry.data.summary}</p>
          <a class="mt-4 inline-flex text-sm font-semibold text-accent hover:text-foreground" href={startEntry.collection === 'blog' ? blogPath(startEntry, true) : toolPath(startEntry, true)}>Markdown export</a>
        </section>
      )}
      <section class="mt-12">
        <h2 class="text-2xl font-bold">Related pages</h2>
        <div class="mt-6 grid gap-4">
          {entries.map((entry) => (
            <article class="rounded-md border border-border/70 bg-card/60 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">{entry.collection}</p>
              <h3 class="mt-2 text-xl font-bold">
                <a class="hover:text-accent" href={entry.collection === 'blog' ? blogPath(entry) : toolPath(entry)}>{entry.data.title}</a>
              </h3>
              <p class="mt-3 leading-7 text-muted-foreground">{entry.data.summary}</p>
              <div class="mt-4 flex flex-wrap gap-4 text-sm font-semibold">
                <a class="text-accent hover:text-foreground" href={entry.collection === 'blog' ? blogPath(entry) : toolPath(entry)}>HTML</a>
                <a class="text-accent hover:text-foreground" href={entry.collection === 'blog' ? blogPath(entry, true) : toolPath(entry, true)}>Markdown</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    </article>
  </main>
</BaseLayout>
