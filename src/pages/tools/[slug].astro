---
import { getCollection, render } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { absoluteUrl, formatDate, localizedPath, type Locale } from '@/lib/site';

export const prerender = true;

export async function getStaticPaths() {
  const tools = (await getCollection('tools')).filter((tool) => tool.data.language === 'de' && !tool.data.draft);
  return tools.map((tool) => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const locale: Locale = 'de';
const { tool } = Astro.props;
const { Content } = await render(tool);
const path = `/tools/${tool.data.slug}/`;
const updated = tool.data.updatedAt ?? tool.data.publishedAt;
const links = [
  tool.data.homepageUrl && { href: tool.data.homepageUrl, label: 'Website' },
  tool.data.repositoryUrl && { href: tool.data.repositoryUrl, label: 'Repository' },
  tool.data.downloadUrl && { href: tool.data.downloadUrl, label: 'Download' },
].filter(Boolean) as { href: string; label: string }[];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: tool.data.title,
    description: tool.data.description,
    datePublished: tool.data.publishedAt.toISOString(),
    dateModified: updated.toISOString(),
    inLanguage: 'de-DE',
    author: {
      '@type': 'Person',
      name: tool.data.author,
    },
    keywords: tool.data.tags,
    mainEntityOfPage: absoluteUrl(localizedPath(locale, path)),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/') },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: absoluteUrl('/tools/') },
      { '@type': 'ListItem', position: 3, name: tool.data.title, item: absoluteUrl(path) },
    ],
  },
];
---

<BaseLayout
  locale={locale}
  title={`${tool.data.title} | Hücki Tools`}
  description={tool.data.description}
  path={path}
  alternatePaths={{ de: path, en: `/tools/${tool.data.canonicalSlug}/` }}
  type="article"
  jsonLd={jsonLd}
  markdownPath={`/tools/${tool.data.slug}.md`}
>
  <Navbar locale={locale} />
  <main id="main-content" class="overflow-hidden px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <article class="mx-auto max-w-4xl min-w-0">
      <a href="/tools/" class="text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">← Alle Tools</a>
      <div class="mt-6 flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-accent/10 px-3 py-1 font-semibold text-accent">{tool.data.category}</span>
        <span class="rounded-full border border-border px-3 py-1 text-muted-foreground">{tool.data.status}</span>
      </div>
      <h1 class="mt-5 break-words text-4xl font-bold tracking-tight [overflow-wrap:anywhere] md:text-6xl">{tool.data.title}</h1>
      <p class="mt-6 break-words text-lg leading-8 text-muted-foreground">{tool.data.description}</p>
      <div class="mt-6 text-sm text-muted-foreground">
        {formatDate(tool.data.publishedAt, locale)} · {tool.data.author}
      </div>
      <section class="mt-10 rounded-md border border-border/70 bg-card/70 p-6">
        <h2 class="text-lg font-semibold">Wofür es gut ist</h2>
        <p class="mt-3 break-words leading-7 text-muted-foreground">{tool.data.summary}</p>
        {links.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-3">
            {links.map((link) => <a href={link.href} class="rounded-md border border-border px-4 py-2 text-sm font-semibold transition hover:border-accent hover:text-accent">{link.label}</a>)}
          </div>
        )}
      </section>
      <div class="blog-prose prose prose-invert prose-stone mt-10 max-w-none break-words [overflow-wrap:anywhere]">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
