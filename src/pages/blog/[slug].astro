---
import { getCollection, render } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { absoluteUrl, formatDate, localizedPath, person, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

export const prerender = true;
export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => post.data.language === 'de' && !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const locale: Locale = 'de';
const { post } = Astro.props;
const { Content } = await render(post);
const copy = portfolioCopy[locale].blog;
const path = `/blog/${post.data.slug}/`;
const published = post.data.publishedAt;
const updated = post.data.updatedAt ?? post.data.publishedAt;
const faqJsonLd = post.data.faqs?.length
  ? [{
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }]
  : [];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: published.toISOString(),
    dateModified: updated.toISOString(),
    inLanguage: 'de-DE',
    author: {
      '@type': 'Person',
      name: person.name,
      url: absoluteUrl('/'),
    },
    publisher: {
      '@type': 'Person',
      name: person.name,
    },
    mainEntityOfPage: absoluteUrl(localizedPath(locale, path)),
    keywords: post.data.tags,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/') },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: absoluteUrl('/blog/') },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: absoluteUrl(path) },
    ],
  },
  ...faqJsonLd,
];
---

<BaseLayout
  locale={locale}
  title={`${post.data.title} | Hücki`}
  description={post.data.description}
  path={path}
  alternatePaths={{ de: path, en: `/blog/${post.data.canonicalSlug}/` }}
  type="article"
  jsonLd={jsonLd}
>
  <Navbar locale={locale} />
  <main class="px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <article class="mx-auto max-w-3xl">
      <p class="uppercase tracking-widest text-muted-foreground text-sm font-semibold">{post.data.topic}</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-bold tracking-tighter">{post.data.title}</h1>
      <p class="mt-6 text-lg text-muted-foreground leading-relaxed">{post.data.description}</p>
      <div class="mt-6 text-sm text-muted-foreground">
        {formatDate(published, locale)} · {post.data.author}
      </div>
      <section class="mt-10 rounded-md border border-border bg-card p-6">
        <h2 class="text-lg font-semibold">{copy.summary}</h2>
        <p class="mt-3 text-muted-foreground leading-relaxed">{post.data.summary}</p>
      </section>
      <div class="prose prose-invert prose-stone mt-10 max-w-none">
        <Content />
      </div>
      {
        post.data.faqs?.length && (
          <section class="mt-12 border-t border-border pt-8">
            <h2 class="text-2xl font-bold">FAQ</h2>
            <div class="mt-6 space-y-5">
              {post.data.faqs.map((faq) => (
                <div>
                  <h3 class="font-semibold">{faq.question}</h3>
                  <p class="mt-2 text-muted-foreground">{faq.answer}</p>
                </div>
              ))}
            </div>
          </section>
        )
      }
    </article>
  </main>
</BaseLayout>
