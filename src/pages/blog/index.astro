---
import { getCollection } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, localizedPath, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

export const prerender = true;
const locale: Locale = 'de';
const copy = portfolioCopy[locale].blog;
const posts = (await getCollection('blog'))
  .filter((post) => post.data.language === locale && !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout locale={locale} title={`${copy.title} | Hücki`} description={copy.description} path="/blog/" jsonLd={[{
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: copy.title,
  description: copy.description,
  inLanguage: 'de-DE',
}]}>
  <Navbar locale={locale} />
  <main class="px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <section class="mx-auto max-w-5xl">
      <p class="uppercase tracking-widest text-muted-foreground text-sm font-semibold">{copy.eyebrow}</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-bold tracking-tighter">{copy.title}</h1>
      <p class="mt-6 max-w-3xl text-lg text-muted-foreground leading-relaxed">{copy.description}</p>
      <div class="mt-12 grid gap-6">
        {posts.map((post) => (
          <article class="rounded-md border border-border bg-card p-6">
            <p class="text-sm text-muted-foreground">{formatDate(post.data.publishedAt, locale)} · {post.data.topic}</p>
            <h2 class="mt-3 text-2xl font-bold"><a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="hover:text-accent">{post.data.title}</a></h2>
            <p class="mt-3 text-muted-foreground leading-relaxed">{post.data.summary}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => <span class="rounded-full border border-border px-3 py-1 text-xs text-foreground/80">{tag}</span>)}
            </div>
            <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="mt-6 inline-flex text-sm font-semibold text-foreground hover:text-accent">{copy.readMore}</a>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
