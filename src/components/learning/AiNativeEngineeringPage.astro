---
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath, person, type Locale } from '@/lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isDe = locale === 'de';
const path = '/ai-native-engineering/';
const title = isDe ? 'AI Native Engineering | Hücki' : 'AI Native Engineering | Hücki';
const description = isDe
  ? 'Ein interaktiver Lernpfad für LLM-native Softwareentwicklung: Tokens, Kontext, Task Contracts, Dekomposition, Evals und produktionsreife AI-Features.'
  : 'An interactive learning path for LLM-native software engineering: tokens, context, Task Contracts, decomposition, evals, and production-grade AI features.';

const copy = isDe
  ? {
      eyebrow: 'AI Native Engineering',
      title: 'Vom Prompt-Schreiber zum AI-System-Builder.',
      intro: 'Ein selbstgeführter Lernpfad für Entwickler:innen, die AI-Features nicht nur demoen, sondern betreiben wollen — mit Kontextbudgets, Task Contracts, Dekomposition, Evals und Fallbacks.',
      deckTitle: 'Becoming LLM-Native',
      deckText: 'Das interaktive Reveal.js Deck läuft hier als statisches Asset in einem Sandbox-iframe. Die Seite bleibt leicht, indexierbar und verlinkbar; der Slide-Modus bleibt vollständig nutzbar.',
      note: 'Pfeiltasten nutzen · Mobile besser quer',
      back: 'Zur Startseite',
      cards: [
        ['01', 'Tokens & Attention', 'Warum Kontextfenster, Positionseffekte und lost-in-the-middle konkrete Architekturentscheidungen sind.'],
        ['02', 'Context Engineering', 'Wie Task Contracts, Schemas und Quellenregeln zuverlässiger sind als längere Prompts.'],
        ['03', 'Agentic Delivery', 'Wie Evals, Traces, Tool-Gates und Incident Playbooks aus AI-Demos betreibbare Systeme machen.'],
      ],
    }
  : {
      eyebrow: 'AI Native Engineering',
      title: 'From prompt writer to AI system builder.',
      intro: 'A self-paced learning path for developers who want to operate AI features, not just demo them — covering context budgets, Task Contracts, decomposition, evals, and fallbacks.',
      deckTitle: 'Becoming LLM-Native',
      deckText: 'The interactive Reveal.js deck runs here as a static asset inside a sandboxed iframe. The page stays lightweight, indexable, and linkable; slide mode stays fully usable.',
      note: 'Use arrow keys · Mobile works best landscape',
      back: 'Back to homepage',
      cards: [
        ['01', 'Tokens & Attention', 'Why context windows, position effects, and lost-in-the-middle are concrete architecture constraints.'],
        ['02', 'Context Engineering', 'How Task Contracts, schemas, and source boundaries beat longer prompts.'],
        ['03', 'Agentic Delivery', 'How evals, traces, tool gates, and incident playbooks turn AI demos into operable systems.'],
      ],
    };
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  path={path}
  alternatePaths={{ de: path, en: path }}
  jsonLd={[{
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: copy.deckTitle,
    description,
    inLanguage: isDe ? 'de-DE' : 'en-US',
    author: { '@type': 'Person', name: person.name },
    educationalLevel: 'Professional',
    learningResourceType: 'Slide deck',
    about: ['LLM-native development', 'AI engineering', 'Context engineering', 'AI agents'],
  }]}
>
  <Navbar locale={locale} />
  <main id="main-content" class="overflow-hidden px-6 pt-32 pb-20 md:px-12 lg:px-24">
    <section class="mx-auto max-w-7xl">
      <a href={localizedPath(locale, '/')} class="inline-flex text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">← {copy.back}</a>
      <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(20rem,0.55fr)] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-accent">{copy.eyebrow}</p>
          <h1 class="mt-5 max-w-5xl text-5xl font-bold leading-[0.95] tracking-tight text-foreground md:text-7xl">{copy.title}</h1>
          <p class="mt-7 max-w-3xl text-lg leading-8 text-muted-foreground md:text-xl md:leading-9">{copy.intro}</p>
        </div>
        <aside class="rounded-2xl border border-accent/30 bg-card/70 p-5 shadow-[0_24px_80px_hsl(var(--accent)/0.10)]">
          <div class="space-y-3">
            {copy.cards.map(([num, cardTitle, text]) => (
              <div class="rounded-lg border border-border/70 bg-background/55 p-4">
                <p class="font-mono text-xs text-accent">{num}</p>
                <h2 class="mt-1 font-semibold text-foreground">{cardTitle}</h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">{text}</p>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="mx-auto mt-12 max-w-7xl">
      <div class="mb-5 flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-accent">Interactive slide mode</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">{copy.deckTitle}</h2>
          <p class="mt-4 max-w-3xl leading-8 text-muted-foreground">{copy.deckText}</p>
        </div>
        <p class="rounded-full border border-border bg-card px-4 py-2 text-sm text-muted-foreground">{copy.note}</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-accent/30 bg-[#061421] shadow-[0_30px_120px_hsl(var(--background)/0.45)]">
        <iframe
          title={copy.deckTitle}
          src="/decks/llm-native-lessons.html"
          sandbox="allow-scripts allow-forms allow-popups"
          loading="lazy"
          class="h-[72vh] min-h-[34rem] w-full bg-[#061421]"
        ></iframe>
      </div>
    </section>
  </main>
</BaseLayout>
