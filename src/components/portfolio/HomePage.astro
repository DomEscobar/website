---
import { getCollection } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, localizedPath, person, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = portfolioCopy[locale];
const allPosts = (await getCollection('blog'))
  .filter((post) => post.data.language === locale && !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const topics = [...new Set(allPosts.map((post) => post.data.topic))];
const currentWork = {
  eyebrow: locale === 'de' ? 'Currently on the bench' : 'Currently on the bench',
  title: locale === 'de' ? 'Aktuell baue ich: Agent Buildprint' : 'Currently building: Agent Buildprint',
  description:
    locale === 'de'
      ? 'Agent Buildprint ist mein aktuelles Hauptprojekt: ausführbare Verträge für Coding Agents — mit Phase-Flow, Evidence Ledger, Review-Schleifen und Replay-Gates statt nur Prompt + Spec.'
      : 'Agent Buildprint is my current main project: executable contracts for coding agents — phase-flow packets, evidence ledgers, review loops, and replay gates instead of just prompt + spec.',
  status: locale === 'de' ? 'ACTIVE BUILD' : 'ACTIVE BUILD',
  phase: locale === 'de' ? 'phase-flow replay + evidence honesty' : 'phase-flow replay + evidence honesty',
  projectTitle: 'Agent Buildprint',
  projectUrl: 'https://agent-buildprint.com/buildprints/',
  projectText:
    locale === 'de'
      ? 'Agenten starten nicht mehr mit einem vagen Auftrag. Sie bootstrappen ein selected-buildprint Paket, lesen die Phase-Flow-Verfassung, schreiben schema-valide Laufzeitbelege und dürfen Blocker nicht als Erfolg verkaufen.'
      : 'Agents no longer start from a vague assignment. They bootstrap a selected-buildprint packet, read the phase-flow constitution, write schema-valid runtime evidence, and cannot sell blockers as success.',
  linkLabel: locale === 'de' ? 'Buildprint Registry öffnen' : 'Open Buildprint registry',
  meta: ['PHASE-FLOW', 'EVIDENCE', 'REVIEWS', 'REPLAY'],
};

const aiNative = {
  eyebrow: 'AI Native Engineering',
  title: locale === 'de' ? 'Vom Prompt-Schreiber zum AI-System-Builder.' : 'From prompt writer to AI system builder.',
  description:
    locale === 'de'
      ? 'Ein selbstgeführter Lernpfad für Entwickler:innen, die AI-Features nicht nur demoen, sondern betreiben wollen — mit Kontextbudgets, Task Contracts, Dekomposition, Evals und Fallbacks.'
      : 'A self-paced learning path for developers who want to operate AI features, not just demo them — covering context budgets, Task Contracts, decomposition, evals, and fallbacks.',
  deckTitle: 'Becoming LLM-Native',
  deckText:
    locale === 'de'
      ? 'Das Slide Deck bleibt interaktiv und läuft hier bewusst sandboxed auf der Startseite.'
      : 'The slide deck stays interactive and runs sandboxed here on the starting page.',
  note: locale === 'de' ? 'Pfeiltasten nutzen · Mobile besser quer' : 'Use arrow keys · Mobile works best landscape',
  cards: locale === 'de'
    ? [
        ['01', 'Tokens & Attention', 'Kontextfenster, Positionseffekte und lost-in-the-middle als echte Architekturgrenzen.'],
        ['02', 'Context Engineering', 'Task Contracts, Schemas und Quellenregeln statt längerer Prompts.'],
        ['03', 'Agentic Delivery', 'Evals, Traces, Tool-Gates und Incident Playbooks für betreibbare AI-Features.'],
      ]
    : [
        ['01', 'Tokens & Attention', 'Context windows, position effects, and lost-in-the-middle as real architecture constraints.'],
        ['02', 'Context Engineering', 'Task Contracts, schemas, and source boundaries instead of longer prompts.'],
        ['03', 'Agentic Delivery', 'Evals, traces, tool gates, and incident playbooks for operable AI features.'],
      ],
};
---

<BaseLayout locale={locale} title={copy.blog.title} description={copy.blog.description} path="/">
  <Navbar locale={locale} />

  <header class="relative isolate overflow-hidden border-b border-border/70 px-6 pt-28 pb-16 md:px-12 md:pt-36 md:pb-24 lg:px-24">
    <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_18%_18%,hsl(var(--accent)/0.18),transparent_30%),radial-gradient(circle_at_88%_64%,hsl(var(--accent)/0.10),transparent_24%),linear-gradient(135deg,hsl(var(--background))_0%,hsl(var(--background))_58%,hsl(var(--card))_100%)]"></div>
    <div class="absolute right-[-12rem] top-20 -z-10 h-[28rem] w-[28rem] rounded-full bg-accent/10 blur-3xl"></div>
    <div class="mx-auto grid max-w-7xl min-w-0 items-center gap-12 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <div class="min-w-0">
        <h1 class="max-w-5xl text-6xl font-bold leading-[0.9] tracking-tight text-foreground md:text-8xl lg:text-9xl">
          {copy.blog.title}
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-8 text-muted-foreground md:text-2xl md:leading-9">{copy.blog.intro}</p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={localizedPath(locale, '/blog/')} class="inline-flex min-h-11 items-center rounded-full bg-accent px-5 text-sm font-semibold text-accent-foreground shadow-[0_0_30px_hsl(var(--accent)/0.22)] transition hover:-translate-y-0.5 hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{locale === 'de' ? 'Blog lesen' : 'Read blog'}</a>
          <a href={person.sameAs[1]} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full border border-border bg-card/80 px-5 text-sm font-semibold text-foreground backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/70 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">GitHub</a>
          <a href={person.sameAs[0]} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full border border-border bg-card/80 px-5 text-sm font-semibold text-foreground backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/70 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">LinkedIn</a>
        </div>
      </div>

      <div class="hero-card-stack mx-auto" aria-hidden="true">
        <div class="hero-card-stack__card hero-card-stack__card--back">
          <span>notes</span>
          <small>field logs</small>
        </div>
        <div class="hero-card-stack__card hero-card-stack__card--middle">
          <span>agents</span>
          <small>workflows</small>
        </div>
        <div class="hero-card-stack__card hero-card-stack__card--front">
          <span>code</span>
          <small>experiments</small>
        </div>
      </div>
    </div>
  </header>

  <main class="w-full">
    <section class="relative overflow-hidden border-b border-border/70 px-6 py-14 md:px-12 md:py-20 lg:px-24" aria-labelledby="current-work-title">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/70 to-transparent"></div>
      <div class="absolute left-6 top-10 -z-10 h-40 w-40 rounded-full bg-accent/10 blur-3xl md:left-20"></div>
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
        <div data-motion="reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-accent">{currentWork.eyebrow}</p>
          <h2 id="current-work-title" class="mt-4 max-w-xl text-3xl font-bold tracking-tight text-foreground md:text-5xl">
            {currentWork.title}
          </h2>
          <p class="mt-5 max-w-2xl leading-8 text-muted-foreground">{currentWork.description}</p>
        </div>

        <article class="group relative overflow-hidden rounded-2xl border border-accent/35 bg-card/75 p-1 shadow-[0_24px_80px_hsl(var(--accent)/0.10)] backdrop-blur" data-motion="reveal">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_16%,hsl(var(--accent)/0.20),transparent_28%),linear-gradient(135deg,hsl(var(--accent)/0.10),transparent_34%)] opacity-80 transition group-hover:opacity-100"></div>
          <div class="relative rounded-[0.85rem] border border-border/70 bg-background/80 p-6 md:p-8">
            <div class="flex flex-wrap items-center gap-3">
              <span class="rounded-full border border-accent/50 bg-accent/15 px-3 py-1 text-xs font-bold uppercase tracking-[0.22em] text-accent">{currentWork.status}</span>
              <span class="text-xs uppercase tracking-[0.22em] text-muted-foreground">{currentWork.phase}</span>
            </div>

            <div class="mt-7 grid gap-6 md:grid-cols-[minmax(0,1fr)_13rem] md:items-end">
              <div>
                <h3 class="text-3xl font-bold tracking-tight md:text-4xl">{currentWork.projectTitle}</h3>
                <p class="mt-4 max-w-2xl leading-8 text-muted-foreground">{currentWork.projectText}</p>
              </div>

              <div class="rounded-xl border border-border/70 bg-card/70 p-4 font-mono text-xs text-muted-foreground">
                <div class="mb-3 flex items-center gap-1.5" aria-hidden="true">
                  <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-yellow-300/80"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-green-400/80"></span>
                </div>
                <pre class="whitespace-pre-wrap leading-6">$ agb start
→ phase before code
→ evidence before trust
→ replay before done</pre>
              </div>
            </div>

            <div class="mt-7 flex flex-wrap items-center justify-between gap-4 border-t border-border/70 pt-5">
              <div class="flex flex-wrap gap-2">
                {currentWork.meta.map((item) => (
                  <span class="rounded-full border border-border bg-card/80 px-3 py-1 text-xs font-semibold text-muted-foreground">{item}</span>
                ))}
              </div>
              <a href={currentWork.projectUrl} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full bg-accent px-5 text-sm font-semibold text-accent-foreground transition hover:-translate-y-0.5 hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                {currentWork.linkLabel} →
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section id="ai-native-engineering" class="relative overflow-hidden border-b border-border/70 px-6 py-14 md:px-12 md:py-20 lg:px-24" aria-labelledby="ai-native-title">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
      <div class="absolute right-8 top-16 -z-10 h-56 w-56 rounded-full bg-accent/10 blur-3xl"></div>
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:items-end">
          <div data-motion="reveal">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-accent">{aiNative.eyebrow}</p>
            <h2 id="ai-native-title" class="mt-4 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-foreground md:text-6xl">
              {aiNative.title}
            </h2>
            <p class="mt-5 max-w-2xl text-lg leading-8 text-muted-foreground">{aiNative.description}</p>
          </div>

          <div class="grid gap-3 md:grid-cols-3 lg:grid-cols-1" data-motion="reveal">
            {aiNative.cards.map(([num, title, text]) => (
              <div class="rounded-xl border border-border/70 bg-card/70 p-4">
                <p class="font-mono text-xs text-accent">{num}</p>
                <h3 class="mt-1 font-semibold text-foreground">{title}</h3>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <a href={localizedPath(locale, '/ai-native-engineering/')} class="group mt-8 block overflow-hidden rounded-2xl border border-accent/30 bg-card/70 p-1 shadow-[0_30px_120px_hsl(var(--accent)/0.10)] transition hover:-translate-y-1 hover:border-accent/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-motion="reveal">
          <div class="relative overflow-hidden rounded-[0.9rem] border border-border/70 bg-background/80 p-6 md:p-8">
            <div class="absolute right-[-4rem] top-[-4rem] h-44 w-44 rounded-full bg-accent/15 blur-3xl transition group-hover:bg-accent/25"></div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">68 slides · self-paced · interactive</p>
            <h3 class="mt-3 text-2xl font-bold tracking-tight text-foreground md:text-4xl">{aiNative.deckTitle}</h3>
            <p class="mt-3 max-w-2xl leading-7 text-muted-foreground">
              {locale === 'de'
                ? 'Öffnet den kompletten Lernpfad mit interaktivem Slide Deck, Kontextmodellen, Task Contracts und operablen AI-Feature-Patterns.'
                : 'Open the full learning path with the interactive slide deck, context models, Task Contracts, and operable AI-feature patterns.'}
            </p>
            <span class="mt-6 inline-flex min-h-11 items-center rounded-full bg-accent px-5 text-sm font-semibold text-accent-foreground transition group-hover:bg-accent/90">
              {locale === 'de' ? 'AI Native Engineering öffnen' : 'Open AI Native Engineering'} →
            </span>
          </div>
        </a>
      </div>
    </section>

    <!-- Topic filter -->
    <nav class="overflow-hidden border-b border-border/70 px-6 py-5 md:px-12 lg:px-24">
      <div class="mx-auto flex max-w-7xl gap-2 overflow-x-auto pb-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <a href={localizedPath(locale, '/blog/')}
          class="shrink-0 rounded-full border border-border bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent transition hover:bg-accent/20">
          {locale === 'de' ? 'Alle' : 'All'}
        </a>
        {topics.map((topic) => (
          <a href={localizedPath(locale, '/blog/') + `?topic=${encodeURIComponent(topic)}`}
            class="shrink-0 rounded-full border border-border px-4 py-1.5 text-sm font-medium text-muted-foreground transition hover:border-accent/60 hover:text-foreground">
            {topic}
          </a>
        ))}
      </div>
    </nav>

    <!-- All posts -->
    <section class="px-6 py-16 md:px-12 md:py-24 lg:px-24">
      <div class="mx-auto max-w-7xl space-y-6">
        {allPosts.map((post, index) => (
          <article class={`rounded-md border border-border/70 bg-card/60 p-6 transition hover:-translate-y-0.5 hover:border-accent/80 ${index === 0 ? 'md:p-8' : ''}`} data-motion="reveal">
            <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
              <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt, locale)}</time>
              <span>·</span>
              <span class="text-accent">{post.data.topic}</span>
            </div>
            <h2 class={`mt-3 font-bold tracking-tight ${index === 0 ? 'text-3xl md:text-4xl' : 'text-2xl'}`}>
              <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{post.data.title}</a>
            </h2>
            <p class="mt-3 max-w-3xl leading-7 text-muted-foreground">{post.data.summary}</p>
            <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="mt-5 inline-flex text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
              {copy.blog.readMore} →
            </a>
          </article>
        ))}
      </div>
    </section>

  </main>

  <footer class="border-t border-border/70 px-6 py-8 md:px-12 lg:px-24">
    <p class="mx-auto max-w-7xl text-sm text-muted-foreground">&copy; {new Date().getFullYear()} {copy.copyright}</p>
  </footer>
</BaseLayout>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    const revealItems = document.querySelectorAll<HTMLElement>('[data-motion="reveal"]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
    );

    revealItems.forEach((item) => {
      if (item.getBoundingClientRect().top < window.innerHeight * 0.95) {
        item.classList.add('is-visible');
      } else {
        observer.observe(item);
      }
    });
    document.documentElement.classList.add('motion-ready');
  }
</script>
