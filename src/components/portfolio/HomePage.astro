---
import { getCollection } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, localizedPath, person, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = portfolioCopy[locale];
const allPosts = (await getCollection('blog'))
  .filter((post) => post.data.language === locale && !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const topics = [...new Set(allPosts.map((post) => post.data.topic))];
---

<BaseLayout locale={locale} title={copy.blog.title} description={copy.blog.description} path="/">
  <Navbar locale={locale} />

  <header class="relative isolate overflow-hidden border-b border-border/70 px-6 pt-28 pb-16 md:px-12 md:pt-36 md:pb-24 lg:px-24">
    <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_18%_18%,hsl(var(--accent)/0.18),transparent_30%),radial-gradient(circle_at_88%_64%,hsl(var(--accent)/0.10),transparent_24%),linear-gradient(135deg,hsl(var(--background))_0%,hsl(var(--background))_58%,hsl(var(--card))_100%)]"></div>
    <div class="absolute right-[-12rem] top-20 -z-10 h-[28rem] w-[28rem] rounded-full bg-accent/10 blur-3xl"></div>
    <div class="mx-auto grid max-w-7xl min-w-0 items-center gap-12 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <div class="min-w-0">
        <h1 class="max-w-5xl text-6xl font-bold leading-[0.9] tracking-tight text-foreground md:text-8xl lg:text-9xl">
          {copy.blog.title}
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-8 text-muted-foreground md:text-2xl md:leading-9">{copy.blog.intro}</p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={localizedPath(locale, '/blog/')} class="inline-flex min-h-11 items-center rounded-full bg-accent px-5 text-sm font-semibold text-accent-foreground shadow-[0_0_30px_hsl(var(--accent)/0.22)] transition hover:-translate-y-0.5 hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{locale === 'de' ? 'Blog lesen' : 'Read blog'}</a>
          <a href={person.sameAs[1]} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full border border-border bg-card/80 px-5 text-sm font-semibold text-foreground backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/70 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">GitHub</a>
          <a href={person.sameAs[0]} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full border border-border bg-card/80 px-5 text-sm font-semibold text-foreground backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/70 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">LinkedIn</a>
        </div>
      </div>

      <div class="hero-card-stack mx-auto" aria-hidden="true">
        <div class="hero-card-stack__card hero-card-stack__card--back">
          <span>notes</span>
          <small>field logs</small>
        </div>
        <div class="hero-card-stack__card hero-card-stack__card--middle">
          <span>agents</span>
          <small>workflows</small>
        </div>
        <div class="hero-card-stack__card hero-card-stack__card--front">
          <span>code</span>
          <small>experiments</small>
        </div>
      </div>
    </div>
  </header>

  <main class="w-full">
    <!-- Topic filter -->
    <nav class="overflow-hidden border-b border-border/70 px-6 py-5 md:px-12 lg:px-24">
      <div class="mx-auto flex max-w-7xl gap-2 overflow-x-auto pb-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <a href={localizedPath(locale, '/blog/')}
          class="shrink-0 rounded-full border border-border bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent transition hover:bg-accent/20">
          {locale === 'de' ? 'Alle' : 'All'}
        </a>
        {topics.map((topic) => (
          <a href={localizedPath(locale, '/blog/') + `?topic=${encodeURIComponent(topic)}`}
            class="shrink-0 rounded-full border border-border px-4 py-1.5 text-sm font-medium text-muted-foreground transition hover:border-accent/60 hover:text-foreground">
            {topic}
          </a>
        ))}
      </div>
    </nav>

    <!-- All posts -->
    <section class="px-6 py-16 md:px-12 md:py-24 lg:px-24">
      <div class="mx-auto max-w-7xl space-y-6">
        {allPosts.map((post, index) => (
          <article class={`rounded-md border border-border/70 bg-card/60 p-6 transition hover:-translate-y-0.5 hover:border-accent/80 ${index === 0 ? 'md:p-8' : ''}`} data-motion="reveal">
            <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
              <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt, locale)}</time>
              <span>·</span>
              <span class="text-accent">{post.data.topic}</span>
            </div>
            <h2 class={`mt-3 font-bold tracking-tight ${index === 0 ? 'text-3xl md:text-4xl' : 'text-2xl'}`}>
              <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{post.data.title}</a>
            </h2>
            <p class="mt-3 max-w-3xl leading-7 text-muted-foreground">{post.data.summary}</p>
            <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="mt-5 inline-flex text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
              {copy.blog.readMore} →
            </a>
          </article>
        ))}
      </div>
    </section>

  </main>

  <footer class="border-t border-border/70 px-6 py-8 md:px-12 lg:px-24">
    <p class="mx-auto max-w-7xl text-sm text-muted-foreground">&copy; {new Date().getFullYear()} {copy.copyright}</p>
  </footer>
</BaseLayout>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    const revealItems = document.querySelectorAll<HTMLElement>('[data-motion="reveal"]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
    );

    revealItems.forEach((item) => {
      if (item.getBoundingClientRect().top < window.innerHeight * 0.95) {
        item.classList.add('is-visible');
      } else {
        observer.observe(item);
      }
    });
    document.documentElement.classList.add('motion-ready');
  }
</script>
