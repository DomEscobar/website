---
import { getCollection } from 'astro:content';
import Navbar from '@/components/portfolio/Navbar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, localizedPath, person, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = portfolioCopy[locale];
const allPosts = (await getCollection('blog'))
  .filter((post) => post.data.language === locale && !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const topics = [...new Set(allPosts.map((post) => post.data.topic))];
---

<BaseLayout locale={locale} title={copy.blog.title} description={copy.blog.description} path="/">
  <Navbar locale={locale} />

  <header class="relative isolate overflow-hidden border-b border-border/70 px-6 pt-28 pb-16 md:px-12 md:pt-36 md:pb-24 lg:px-24">
    <div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_18%_12%,hsl(var(--accent)/0.22),transparent_28%),radial-gradient(circle_at_82%_26%,hsl(var(--foreground)/0.10),transparent_24%),linear-gradient(115deg,hsl(var(--background))_0%,hsl(var(--background))_48%,hsl(var(--card))_100%)]"></div>
    <div class="absolute inset-0 -z-10 opacity-[0.13] [background-image:linear-gradient(hsl(var(--foreground))_1px,transparent_1px),linear-gradient(90deg,hsl(var(--foreground))_1px,transparent_1px)] [background-size:38px_38px]"></div>
    <div class="mx-auto grid max-w-7xl items-end gap-10 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <div>
        <p class="inline-flex rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-accent shadow-[0_0_40px_hsl(var(--accent)/0.18)]">{copy.blog.eyebrow}</p>
        <h1 class="mt-6 max-w-5xl text-5xl font-bold leading-[0.94] tracking-tight text-foreground md:text-7xl lg:text-8xl">
          {copy.blog.title}
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-7 text-muted-foreground md:text-lg">{copy.blog.intro}</p>
        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a href={person.sameAs[0]} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full border border-border bg-card/80 px-5 text-sm font-semibold text-foreground shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/70 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">LinkedIn</a>
          <a href={person.sameAs[1]} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center rounded-full border border-border bg-card/80 px-5 text-sm font-semibold text-foreground shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/70 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">GitHub</a>
        </div>
      </div>

      <aside class="hero-orbit relative overflow-hidden rounded-[2rem] border border-border/80 bg-card/75 p-6 shadow-2xl shadow-accent/10 backdrop-blur" aria-label={locale === 'de' ? 'Kundenerfahrung' : 'Customer experience'}>
        <div class="absolute right-6 top-6 h-3 w-3 rounded-full bg-accent shadow-[0_0_28px_hsl(var(--accent))]"></div>
        <div class="relative z-10">
          <p class="text-xs font-semibold uppercase tracking-[0.26em] text-accent">{locale === 'de' ? 'Customer UX' : 'Customer UX'}</p>
          <p class="mt-5 text-xl font-semibold leading-8 tracking-tight text-foreground">“{copy.blog.customerExperience}”</p>
          <div class="mt-6 flex gap-2 text-xs font-semibold text-muted-foreground">
            <span class="rounded-full bg-background/80 px-3 py-1">UX/UI</span>
            <span class="rounded-full bg-background/80 px-3 py-1">AI-first</span>
            <span class="rounded-full bg-background/80 px-3 py-1">Delivery</span>
          </div>
        </div>
      </aside>
    </div>
  </header>

  <main class="w-full">
    <!-- Topic filter -->
    <nav class="border-b border-border/70 px-6 py-5 md:px-12 lg:px-24">
      <div class="mx-auto flex max-w-7xl flex-wrap gap-2">
        <a href={localizedPath(locale, '/blog/')}
          class="rounded-full border border-border bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent transition hover:bg-accent/20">
          {locale === 'de' ? 'Alle' : 'All'}
        </a>
        {topics.map((topic) => (
          <a href={localizedPath(locale, '/blog/') + `?topic=${encodeURIComponent(topic)}`}
            class="rounded-full border border-border px-4 py-1.5 text-sm font-medium text-muted-foreground transition hover:border-accent/60 hover:text-foreground">
            {topic}
          </a>
        ))}
      </div>
    </nav>

    <!-- All posts -->
    <section class="px-6 py-16 md:px-12 md:py-24 lg:px-24">
      <div class="mx-auto max-w-7xl space-y-6">
        {allPosts.map((post, index) => (
          <article class={`rounded-md border border-border/70 bg-card/60 p-6 transition hover:-translate-y-0.5 hover:border-accent/80 ${index === 0 ? 'md:p-8' : ''}`} data-motion="reveal">
            <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
              <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt, locale)}</time>
              <span>·</span>
              <span class="text-accent">{post.data.topic}</span>
            </div>
            <h2 class={`mt-3 font-bold tracking-tight ${index === 0 ? 'text-3xl md:text-4xl' : 'text-2xl'}`}>
              <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{post.data.title}</a>
            </h2>
            <p class="mt-3 max-w-3xl leading-7 text-muted-foreground">{post.data.summary}</p>
            <a href={localizedPath(locale, `/blog/${post.data.slug}/`)} class="mt-5 inline-flex text-sm font-semibold text-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
              {copy.blog.readMore} →
            </a>
          </article>
        ))}
      </div>
    </section>

  </main>

  <footer class="border-t border-border/70 px-6 py-8 md:px-12 lg:px-24">
    <p class="mx-auto max-w-7xl text-sm text-muted-foreground">&copy; {new Date().getFullYear()} {copy.copyright}</p>
  </footer>
</BaseLayout>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    const revealItems = document.querySelectorAll<HTMLElement>('[data-motion="reveal"]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
    );

    revealItems.forEach((item) => {
      if (item.getBoundingClientRect().top < window.innerHeight * 0.95) {
        item.classList.add('is-visible');
      } else {
        observer.observe(item);
      }
    });
    document.documentElement.classList.add('motion-ready');
  }
</script>
