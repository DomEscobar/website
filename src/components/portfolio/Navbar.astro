---
import { localizedPath, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = portfolioCopy[locale];
const homeHref = localizedPath(locale, '/');
const blogHref = localizedPath(locale, '/blog/');
const toolsHref = localizedPath(locale, '/tools/');
const learningHref = localizedPath(locale, '/ai-native-engineering/');
const switchHref = locale === 'de' ? '/en/' : '/';
const switchLabel = locale === 'de' ? 'EN' : 'DE';
const navItems = [
  { href: learningHref, label: 'AI Native' },
  { href: toolsHref, label: copy.nav.tools },
  { href: blogHref, label: copy.nav.blog },
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-accent focus:px-4 focus:py-3 focus:text-sm focus:font-semibold focus:text-accent-foreground">
  Skip to content
</a>
<nav class="fixed left-0 right-0 top-0 z-50 border-b border-border/70 bg-background/82 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-6 md:px-12">
    <div class="flex min-h-20 items-center justify-between gap-4">
      <a href={homeHref} class="text-2xl font-bold tracking-tight text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">huecki</a>
      <div class="hidden items-center gap-7 md:flex">
        {navItems.map((item) => (
          <a href={item.href} class="text-sm font-medium text-muted-foreground transition hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{item.label}</a>
        ))}
      </div>
      <div class="flex items-center gap-2">
        <a href={switchHref} class="rounded-md border border-border px-3 py-2 text-sm font-semibold uppercase transition hover:border-accent hover:bg-card focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{switchLabel}</a>
        <details class="group relative md:hidden">
          <summary class="flex min-h-10 min-w-10 cursor-pointer list-none items-center justify-center rounded-md border border-border px-3 py-2 text-sm font-semibold text-foreground transition hover:border-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" aria-label={copy.nav.menu}>
            <span aria-hidden="true">☰</span>
          </summary>
          <div class="absolute right-0 mt-3 w-56 rounded-md border border-border bg-card p-2 shadow-2xl">
            {navItems.map((item) => (
              <a href={item.href} class="block rounded-sm px-3 py-3 text-sm font-medium text-muted-foreground transition hover:bg-background hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">{item.label}</a>
            ))}
          </div>
        </details>
      </div>
    </div>
  </div>
</nav>
