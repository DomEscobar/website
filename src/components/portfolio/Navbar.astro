---
import { localizedPath, type Locale } from '@/lib/site';
import { portfolioCopy } from '@/lib/portfolio-content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = portfolioCopy[locale];
const homeHref = localizedPath(locale, '/');
const blogHref = localizedPath(locale, '/blog/');
const switchHref = locale === 'de' ? '/en/' : '/';
const switchLabel = locale === 'de' ? 'EN' : 'DE';
const homeAnchor = (id: string) => `${homeHref}#${id}`;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-sm border-b border-border">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="flex justify-between items-center h-20">
      <a href={homeHref} class="text-2xl font-bold tracking-tighter text-foreground">Hücki.</a>
      <div class="hidden md:flex items-center space-x-8">
        <a href={homeAnchor('about')} class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">{copy.nav.about}</a>
        <a href={homeAnchor('projects')} class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">{copy.nav.projects}</a>
        <a href={blogHref} class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">{copy.nav.blog}</a>
        <a href={homeAnchor('skills')} class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">{copy.nav.skills}</a>
        <a href={homeAnchor('contact')} class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">{copy.nav.contact}</a>
      </div>
      <a href={switchHref} class="border border-border rounded-md px-3 py-2 text-sm font-semibold uppercase hover:bg-card transition-colors">{switchLabel}</a>
    </div>
  </div>
</nav>
