---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<section class="not-prose my-8 grid gap-3 sm:grid-cols-3">
  {metrics.map((metric) => (
    <div class="rounded-2xl border border-border/70 bg-card/70 p-5 shadow-sm">
      <div class="text-3xl font-black tracking-tight text-accent">{metric.value}</div>
      <div class="mt-2 text-sm leading-6 text-muted-foreground">{metric.label}</div>
    </div>
  ))}
</section>
