---
interface Props {
  title?: string;
  doLabel?: string;
  dontLabel?: string;
  doItems: string[];
  dontItems: string[];
}

const { title = 'Use / avoid', doLabel = 'Use when', dontLabel = 'Avoid when', doItems, dontItems } = Astro.props;
---

<section class="not-prose my-8 rounded-2xl border border-border/70 bg-card/70 p-5 shadow-sm md:p-6">
  <h2 class="text-sm font-bold uppercase tracking-[0.22em] text-accent">{title}</h2>
  <div class="mt-5 grid gap-4 md:grid-cols-2">
    <div class="rounded-xl border border-accent/20 bg-accent/10 p-4">
      <h3 class="font-bold text-foreground">{doLabel}</h3>
      <ul class="mt-3 space-y-2 text-sm leading-6 text-foreground/90">
        {doItems.map((item) => <li>✓ {item}</li>)}
      </ul>
    </div>
    <div class="rounded-xl border border-border/70 bg-background/55 p-4">
      <h3 class="font-bold text-foreground">{dontLabel}</h3>
      <ul class="mt-3 space-y-2 text-sm leading-6 text-muted-foreground">
        {dontItems.map((item) => <li>× {item}</li>)}
      </ul>
    </div>
  </div>
</section>
