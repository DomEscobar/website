---
interface Props {
  title?: string;
  items?: string[];
  points?: string[];
}

const { title = 'Key points', items = Astro.props.points ?? [] } = Astro.props;
---

<section class="not-prose my-8 rounded-2xl border border-border/70 bg-card/70 p-5 shadow-sm md:p-6">
  <h2 class="text-sm font-bold uppercase tracking-[0.22em] text-accent">{title}</h2>
  <ul class="mt-5 grid gap-3 md:grid-cols-2">
    {items.map((item) => (
      <li class="flex gap-3 rounded-xl border border-border/60 bg-background/55 p-4 text-sm leading-6 text-foreground/90">
        <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent shadow-[0_0_18px_hsl(var(--accent))]"></span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</section>
