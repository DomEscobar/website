---
interface CompareRow {
  left: string;
  right: string;
}

interface Props {
  title?: string;
  leftLabel?: string;
  rightLabel?: string;
  rows: CompareRow[];
}

const { title = 'Compare', leftLabel = 'Before', rightLabel = 'After', rows } = Astro.props;
---

<section class="not-prose my-8 overflow-hidden rounded-2xl border border-border/70 bg-card/70 shadow-sm">
  <div class="border-b border-border/70 px-5 py-4 md:px-6">
    <h2 class="text-sm font-bold uppercase tracking-[0.22em] text-accent">{title}</h2>
  </div>
  <div class="grid md:grid-cols-2">
    <div class="border-b border-border/70 p-5 md:border-b-0 md:border-r md:p-6">
      <h3 class="text-xs font-bold uppercase tracking-[0.18em] text-muted-foreground">{leftLabel}</h3>
      <ul class="mt-4 space-y-3">
        {rows.map((row) => <li class="rounded-xl bg-background/55 p-3 text-sm leading-6 text-muted-foreground">{row.left}</li>)}
      </ul>
    </div>
    <div class="p-5 md:p-6">
      <h3 class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{rightLabel}</h3>
      <ul class="mt-4 space-y-3">
        {rows.map((row) => <li class="rounded-xl border border-accent/20 bg-accent/10 p-3 text-sm leading-6 text-foreground">{row.right}</li>)}
      </ul>
    </div>
  </div>
</section>
